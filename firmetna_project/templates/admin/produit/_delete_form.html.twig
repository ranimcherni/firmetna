<form method="post" action="{{ path('app_admin_produit_delete', {'id': produit.id}) }}" onsubmit="return confirm('Supprimer ce produit ?');" class="d-inline w-100">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ produit.id) }}">
    <button class="btn btn-outline-danger w-100" style="border-radius: 8px;"><i class="fas fa-trash me-2"></i> Supprimer</button>
</form>
